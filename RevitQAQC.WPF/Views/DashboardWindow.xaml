<Window x:Class="RevitQAQC.WPF.Views.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:converters="clr-namespace:RevitQAQC.WPF.Converters"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Revit QAQC Dashboard"
        Height="720"
        Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#F4F6F9">
    
    <Window.Resources>

        <converters:BooleanToStatusConverter
        x:Key="StatusConverter"/>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">

            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Width" Value="140"/>
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="BorderBrush" Value="#2563EB"/>
            <Setter Property="Cursor" Value="Hand"/>

        </Style>

    </Window.Resources>

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->

        <TextBlock
            Grid.Row="0"
            Text="Revit QAQC Dashboard"
            FontSize="30"
            FontWeight="Bold"
            Foreground="#2C3E50"
            Margin="0,0,0,20"/>

        <!-- Cards -->

        <Grid Grid.Row="1"
              Margin="0,0,0,20">

            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            
            <!-- Project Card -->

            <Border Grid.Column="0"
                    Margin="0,0,15,0"
                    Background="White"
                    CornerRadius="8"
                    BorderBrush="#DDDDDD"
                    BorderThickness="1"
                    Padding="15">

                <StackPanel>

                    <TextBlock
                        Text="PROJECT"
                        Foreground="Gray"
                        FontWeight="Bold"/>

                    <TextBlock
                        Margin="0,8,0,0"
                        FontSize="18"
                        FontWeight="Bold"
                        Text="{Binding Report.ProjectName}"/>

                </StackPanel>

            </Border>

            <!-- Health Score -->

            <Border Grid.Column="1"
              Margin="0,0,15,0"
              Background="White"
              CornerRadius="10"
              BorderBrush="#E5E7EB"
              BorderThickness="1"
              Padding="20">

                <StackPanel
                  HorizontalAlignment="Center">

                    <TextBlock
                  Text="MODEL HEALTH"
                  FontSize="14"
                  FontWeight="SemiBold"
                  Foreground="#6B7280"
                  HorizontalAlignment="Center"/>

                    <TextBlock
                    Margin="0,12,0,0"
                    Text="{Binding Report.HealthScore.Score,StringFormat={}{0:F2}%}"
                    FontSize="48"
                    FontWeight="Bold"
                    Foreground="#22C55E"
                    HorizontalAlignment="Center"/>

                    <TextBlock
                     Margin="0,5,0,10"
                     Text="{Binding Report.HealthScore.Grade}"
                     FontSize="20"
                     FontWeight="SemiBold"
                     Foreground="#374151"
                      HorizontalAlignment="Center"/>

                    <ProgressBar
                     Width="220"
                     Height="12"
                     Maximum="100"
                      Value="{Binding Report.HealthScore.Score}"/>

                </StackPanel>

            </Border>

            <!-- Checks -->

            <Border Grid.Column="2"
                    Background="White"
                    CornerRadius="8"
                    BorderBrush="#DDDDDD"
                    BorderThickness="1"
                    Padding="15">

                <StackPanel>

                    <TextBlock
                        Text="TOTAL CHECKS"
                        Foreground="Gray"
                        FontWeight="Bold"/>

                    <TextBlock
                        FontSize="38"
                        FontWeight="Bold"
                        Text="{Binding Report.CheckResults.Count}"/>

                </StackPanel>

            </Border>

            <!-- Failed Checks -->

            <Border Grid.Column="3"
                 Margin="15,0,0,0"
                Background="White"
                CornerRadius="10"
                BorderBrush="#E5E7EB"
                BorderThickness="1"
                Padding="20">

                <StackPanel HorizontalAlignment="Center">

                    <TextBlock
                        Text="FAILED CHECKS"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Foreground="#6B7280"
                        HorizontalAlignment="Center"/>

                    <TextBlock
                        x:Name="FailedChecksText"
                        Margin="0,12,0,0"
                        Text="{Binding FailedChecks}"
                        FontSize="42"
                        FontWeight="Bold"
                        Foreground="#DC2626"
                        HorizontalAlignment="Center"/>

                </StackPanel>

            </Border>

        </Grid>

        <!-- Results -->

        <Border Grid.Row="3"
                Background="White"
                CornerRadius="8"
                BorderBrush="#DDDDDD"
                BorderThickness="1"
                Padding="10">

            <DataGrid
                AutoGenerateColumns="False"
                 CanUserAddRows="False"
                CanUserDeleteRows="False"
                IsReadOnly="True"
                HeadersVisibility="Column"
                GridLinesVisibility="Horizontal"
                RowHeight="38"
                ColumnHeaderHeight="42"
                AlternatingRowBackground="#F8FAFC"
                Background="White"
                BorderThickness="0"
                FontSize="13"
                ItemsSource="{Binding Report.CheckResults}">

                <DataGrid.Columns>

                    <DataGridTextColumn
                        Header="Check Name"
                        Width="250"
                        Binding="{Binding CheckName}"/>

                    <DataGridTextColumn
                        Header="Issues"
                        Width="90"
                        Binding="{Binding IssueCount}"/>

                    <DataGridTextColumn
                        Header="Status"
                        Width="100"
                        Binding="{Binding IsPass,
                      Converter={StaticResource StatusConverter}}"/> 
                    
                    <DataGridTextColumn
                        Header="Message"
                        Width="*"
                        Binding="{Binding Message}"/>

                </DataGrid.Columns>

            </DataGrid>

        </Border>

        <!-- Buttons -->

        <!-- Buttons -->

        <StackPanel Grid.Row="4"
            Orientation="Horizontal"
            HorizontalAlignment="Right"
            Margin="0,20,0,0">
            <Button
            x:Name="ExportPdfButton"
            Style="{StaticResource PrimaryButtonStyle}"
            Margin="0,0,10,0"
            Content="Export PDF"
            Click="ExportPdfButton_Click"/>

            <Button
            x:Name="ExportJsonButton"
            Style="{StaticResource PrimaryButtonStyle}"
            Margin="0,0,10,0"
            Content="Export JSON"
            Click="ExportJsonButton_Click"/>    

            <Button
            x:Name="CloseButton"
            Style="{StaticResource PrimaryButtonStyle}"
            Background="#DC2626"
            BorderBrush="#DC2626"
            Content="Close"
            Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>

</Window>